<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.grincare.controller.KonsultasiController"
      style="-fx-background-color: #f0f4f8;">

    <!-- ===== HEADER ===== -->
    <HBox spacing="14"
          style="-fx-background-color: white;
                 -fx-padding: 14 24 14 24;
                 -fx-alignment: CENTER_LEFT;">

        <!-- Logo: kotak rounded gradient teal→biru -->
        <StackPane style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #26c6da, #1565c0);
                          -fx-background-radius: 14;
                          -fx-min-width: 52; -fx-min-height: 52;
                          -fx-pref-width: 52; -fx-pref-height: 52;
                          -fx-alignment: CENTER;">
            <Label text="😊" style="-fx-font-size: 26px;"/>
        </StackPane>

        <!-- Judul + subjudul -->
        <VBox spacing="2" style="-fx-alignment: CENTER_LEFT;">
            <Label text="Klinik Gigi Sehat"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <Label text="Solusi Kesehatan Gigi Anda"
                   style="-fx-font-size: 12px; -fx-text-fill: #999;"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Tanggal + jam -->
        <VBox spacing="2" style="-fx-alignment: CENTER_RIGHT;">
            <Label fx:id="labelTanggal" text=""
                   style="-fx-font-size: 12px; -fx-text-fill: #999;"/>
            <Label fx:id="labelJam" text=""
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1976d2;"/>
        </VBox>

        <!-- Login Admin (dekoratif) -->
        <Button text=" Login Admin"
                style="-fx-background-color: transparent;
                       -fx-border-color: #1976d2; -fx-border-radius: 20; -fx-border-width: 1;
                       -fx-background-radius: 20;
                       -fx-text-fill: #1976d2; -fx-font-size: 12px;
                       -fx-padding: 6 18 6 18; -fx-cursor: hand;"/>
    </HBox>

    <!-- Garis pemisah gradient biru di bawah header -->
    <Region style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #1565c0, #26c6da);
                   -fx-min-height: 3; -fx-pref-height: 3; -fx-max-height: 3;"/>

    <!-- Link kembali (kecil, tidak mencolok) -->
    <HBox style="-fx-padding: 8 24 0 24;">
        <Button text="← Kembali ke Kategori" onAction="#handleKembali"
                style="-fx-background-color: transparent; -fx-border-color: transparent;
                       -fx-text-fill: #aaa; -fx-font-size: 11px;
                       -fx-padding: 0; -fx-cursor: hand;"/>
    </HBox>

    <!-- ===== KONTEN UTAMA (2 kolom) ===== -->
    <HBox spacing="16" VBox.vgrow="ALWAYS"
          style="-fx-padding: 10 24 20 24; -fx-alignment: TOP_LEFT;">

        <!-- ========== KOLOM KIRI: CHAT CARD ========== -->
        <VBox HBox.hgrow="ALWAYS"
              style="-fx-background-color: white;
                     -fx-background-radius: 16;
                     -fx-effect: dropshadow(three-pass-box, #c8c8c8, 10, 0, 0, 2);">

            <!-- Area pesan chat (tumbuh mengisi sisa tinggi) -->
            <VBox VBox.vgrow="ALWAYS" spacing="14"
                  style="-fx-padding: 20 20 14 20;">

                <!-- Bubble sambutan bot -->
                <HBox spacing="12" style="-fx-alignment: TOP_LEFT;">
                    <StackPane style="-fx-background-color: #e3f2fd;
                                      -fx-background-radius: 21;
                                      -fx-min-width: 42; -fx-min-height: 42;
                                      -fx-pref-width: 42; -fx-pref-height: 42;
                                      -fx-alignment: CENTER;">
                        <Label text="🤖" style="-fx-font-size: 20px;"/>
                    </StackPane>
                    <VBox spacing="4">
                        <Label text="Selamat datang di Klinik Gigi Sehat. Saya adalah asisten virtual Anda. Silakan pilih keluhan Anda atau ketik pertanyaan."
                               wrapText="true" maxWidth="400"
                               style="-fx-background-color: #f0f2f5;
                                      -fx-background-radius: 0 12 12 12;
                                      -fx-padding: 12 16 12 16;
                                      -fx-font-size: 13px; -fx-text-fill: #333;"/>
                        <Label fx:id="labelTimestamp" text=""
                               style="-fx-font-size: 11px; -fx-text-fill: #bbb;"/>
                    </VBox>
                </HBox>

                <!-- Hasil konsultasi Ginny (tersembunyi sampai ada response) -->
                <VBox fx:id="panelHasil" spacing="10" visible="false" managed="false">
                    <HBox spacing="12" style="-fx-alignment: TOP_LEFT;">
                        <StackPane style="-fx-background-color: #e3f2fd;
                                          -fx-background-radius: 21;
                                          -fx-min-width: 42; -fx-min-height: 42;
                                          -fx-pref-width: 42; -fx-pref-height: 42;
                                          -fx-alignment: CENTER;">
                            <Label text="🤖" style="-fx-font-size: 20px;"/>
                        </StackPane>
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <!-- Edukasi: TextArea dirender sebagai bubble -->
                            <TextArea fx:id="areaEdukasi" wrapText="true" editable="false"
                                      prefHeight="100" maxWidth="10000"
                                      style="-fx-control-inner-background: #f0f2f5;
                                             -fx-background-color: #f0f2f5, #f0f2f5;
                                             -fx-background-radius: 0 12 12 12;
                                             -fx-background-insets: 0;
                                             -fx-border-color: transparent; -fx-border-width: 0;
                                             -fx-padding: 12 16 12 16;
                                             -fx-font-size: 13px; -fx-text-fill: #333;"/>
                            <!-- Badge rekomendasi kategori -->
                            <Label fx:id="labelKategoriHasil"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                                          -fx-text-fill: #2e7d32; -fx-padding: 6 12 6 12;
                                          -fx-background-color: #e8f5e9;
                                          -fx-border-color: #4caf50; -fx-border-width: 1;
                                          -fx-border-radius: 6; -fx-background-radius: 6;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Indikator loading -->
                <Label fx:id="labelLoading" text="⏳  Ginny sedang menganalisis keluhan Anda..."
                       visible="false" managed="false"
                       style="-fx-text-fill: #888; -fx-font-style: italic; -fx-font-size: 12px;"/>

                <!-- Label error validasi -->
                <Label fx:id="labelError" text=""
                       style="-fx-text-fill: #cc0000; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Garis pemisah tipis -->
            <Region style="-fx-background-color: #f0f0f0;
                           -fx-min-height: 1; -fx-pref-height: 1; -fx-max-height: 1;"/>

            <!-- Baris hint + tombol Kategori Cepat -->
            <HBox spacing="8" style="-fx-padding: 10 20 10 20; -fx-alignment: CENTER_LEFT;">
                <Label text="Tidak tahu harus ketik apa?"
                       style="-fx-font-size: 12px; -fx-text-fill: #999;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="📋  Kategori Cepat"
                        style="-fx-background-color: #e8f0fe;
                               -fx-border-color: #1976d2; -fx-border-radius: 16; -fx-border-width: 1;
                               -fx-background-radius: 16;
                               -fx-text-fill: #1976d2; -fx-font-size: 11px;
                               -fx-padding: 5 14 5 14; -fx-cursor: hand;"/>
            </HBox>

            <!-- Baris input keluhan + tombol Kirim -->
            <HBox spacing="10" style="-fx-padding: 0 20 14 20; -fx-alignment: CENTER_LEFT;">
                <TextField fx:id="keluhanField" HBox.hgrow="ALWAYS"
                           promptText="Ketik keluhan Anda di sini..."
                           style="-fx-background-color: #f8f9fa;
                                  -fx-background-radius: 24;
                                  -fx-border-color: #e0e0e0; -fx-border-radius: 24; -fx-border-width: 1;
                                  -fx-padding: 10 18 10 18; -fx-font-size: 13px;"/>
                <Button fx:id="btnKirim" text="✈  Kirim" onAction="#handleKirim"
                        style="-fx-background-color: #1976d2; -fx-text-fill: white;
                               -fx-background-radius: 24; -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-padding: 10 22 10 22; -fx-cursor: hand;"/>
            </HBox>

            <!-- Tombol aksi bawah -->
            <HBox spacing="12" style="-fx-padding: 0 20 20 20;">
                <!-- Ambil Antrian: muncul setelah Ginny beri rekomendasi valid -->
                <Button fx:id="btnLanjut" text="Ambil Nomor Antrian"
                        onAction="#handleLanjut"
                        visible="false" managed="false"
                        HBox.hgrow="ALWAYS" maxWidth="10000"
                        style="-fx-background-color: #1976d2; -fx-text-fill: white;
                               -fx-background-radius: 8; -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-padding: 12 0 12 0; -fx-cursor: hand;"/>
                <!-- Lewati: selalu tampil -->
                <Button text="Lewati &amp; Ambil Antrian Manual"
                        onAction="#handleLewati"
                        HBox.hgrow="ALWAYS" maxWidth="10000"
                        style="-fx-background-color: white;
                               -fx-border-color: #1976d2; -fx-border-radius: 8; -fx-border-width: 1;
                               -fx-background-radius: 8;
                               -fx-text-fill: #1976d2; -fx-font-size: 13px;
                               -fx-padding: 12 0 12 0; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <!-- ========== KOLOM KANAN: INFO ANTRIAN ========== -->
        <VBox spacing="12"
              style="-fx-min-width: 290; -fx-pref-width: 310; -fx-max-width: 340;">

            <Label text="Informasi Antrian"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

            <!-- Nomor antrian saat ini -->
            <VBox spacing="6"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 16 18 16 18;
                         -fx-effect: dropshadow(three-pass-box, #d0d0d0, 6, 0, 0, 1);">
                <Label text="Nomor Antrian Saat Ini"
                       style="-fx-font-size: 12px; -fx-text-fill: #999;"/>
                <Label text="—"
                       style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #1976d2;"/>
            </VBox>

            <!-- Estimasi waktu tunggu -->
            <VBox spacing="6"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 16 18 16 18;
                         -fx-effect: dropshadow(three-pass-box, #d0d0d0, 6, 0, 0, 1);">
                <Label text="🕐   Estimasi Waktu Tunggu"
                       style="-fx-font-size: 12px; -fx-text-fill: #999;"/>
                <Label text="15-20 menit"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            </VBox>

            <!-- Jumlah antrian saat ini -->
            <VBox spacing="6"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 16 18 16 18;
                         -fx-effect: dropshadow(three-pass-box, #d0d0d0, 6, 0, 0, 1);">
                <Label text="👥   Jumlah Antrian Saat Ini"
                       style="-fx-font-size: 12px; -fx-text-fill: #999;"/>
                <Label text="—"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            </VBox>

            <!-- Card reminder info -->
            <VBox style="-fx-background-color: #e8f4fd; -fx-background-radius: 12;
                         -fx-padding: 14 16 14 16;">
                <HBox spacing="10" style="-fx-alignment: TOP_LEFT;">
                    <Label text="ℹ" style="-fx-font-size: 16px; -fx-text-fill: #1976d2;"/>
                    <Label text="Harap tunggu nomor Anda dipanggil. Terima kasih atas kesabaran Anda."
                           wrapText="true"
                           style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>
</VBox>
